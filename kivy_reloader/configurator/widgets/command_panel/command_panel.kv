<CommandPanel>:
    orientation: 'vertical'
    size_hint_y: None
    height: dp(196) if self.is_expanded else dp(36)

    canvas.before:
        Color:
            rgba: card_color
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: border_color
        Line:
            points: [self.x, self.top, self.right, self.top]
            width: dp(1)

    # Header (always visible)
    BoxLayout:
        size_hint_y: None
        height: dp(36)
        padding: [dp(8), dp(4), dp(8), dp(4)]
        spacing: dp(8)

        canvas.before:
            Color:
                rgba: muted_color
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: unicode['chevron-up'] if root.is_expanded else unicode['chevron-down']
            font_name: icon_font
            size_hint: None, None
            size: dp(20), dp(28)
            font_size: font_size_base
            color: muted_foreground_color
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            on_touch_down:
                if self.collide_point(*args[1].pos): root.toggle()

        Label:
            text: 'Terminal Output'
            size_hint_x: None
            width: self.texture_size[0] + dp(8)
            font_size: font_size_sm
            color: foreground_color
            bold: True

        Widget:

        Button:
            text: 'Copy log'
            size_hint_x: None
            width: dp(64)
            font_size: font_size_xs
            background_color: muted_color
            color: foreground_color
            on_release: root.copy_log()

    # Content
    BoxLayout:
        orientation: 'vertical'
        padding: [dp(8), dp(4), dp(8), dp(4)]
        spacing: dp(4)

        canvas.before:
            Color:
                rgba: background_color
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(26)
            spacing: dp(4)

            Label:
                text: ('$ ' + root.current_command) if root.current_command else '$ (no command yet)'
                font_size: font_size_xs
                color: success_color if root.current_command else muted_foreground_color
                halign: 'left'
                valign: 'middle'
                text_size: self.width, dp(26)
                padding: [dp(4), 0]

                canvas.before:
                    Color:
                        rgba: muted_color
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [border_radius_sm]

            Button:
                text: 'Copy cmd'
                size_hint_x: None
                width: dp(68)
                font_size: font_size_xs
                background_color: muted_color
                color: foreground_color
                disabled: not root.current_command
                on_release: root.copy_command()

        ScrollView:
            do_scroll_x: False

            Label:
                text: root.output_log if root.output_log else 'Output will appear here...'
                size_hint_y: None
                height: self.texture_size[1]
                font_size: dp(11)
                color: foreground_color if root.output_log else muted_foreground_color
                halign: 'left'
                valign: 'top'
                text_size: self.width, None
                padding: [dp(4), dp(4)]
