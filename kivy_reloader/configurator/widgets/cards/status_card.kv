<StatusRow>:
    size_hint_y: None
    height: dp(48)
    spacing: dp(12)
    padding: [dp(4), dp(4)]

    Label:
        text: root.icon
        size_hint: None, None
        size: dp(28), dp(28)
        font_size: font_size_base
        bold: True
        color: (0.3, 0.85, 0.4, 1) if root.row_status == 'ok' else (1, 0.75, 0.2, 1) if root.row_status == 'warn' else (0.9, 0.3, 0.3, 1) if root.row_status == 'fail' else muted_foreground_color
        halign: 'center'
        valign: 'middle'
        text_size: self.size

    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)

        Label:
            text: root.label
            font_size: font_size_sm
            bold: True
            color: foreground_color
            halign: 'left'
            valign: 'middle'
            text_size: self.width, self.height

        Label:
            text: root.detail
            font_size: font_size_xs
            color: muted_foreground_color
            halign: 'left'
            valign: 'middle'
            text_size: self.width, self.height
            shorten: True
            shorten_from: 'right'


<StatusCard>:
    orientation: 'vertical'
    size_hint_y: None
    height: self.minimum_height

    Card:
        title: f'[size=16][font={emoji_font}]📡[/font][/size] Status — {root.os_label}'
        description: 'Environment checks for your current OS and device setup.'

        BoxLayout:
            orientation: 'vertical'
            spacing: dp(8)
            size_hint_y: None
            height: self.minimum_height

            Separator:

            Button:
                text: 'Refresh'
                size_hint_y: None
                height: dp(36)
                font_size: font_size_sm
                background_color: primary_color
                color: primary_foreground_color
                on_release: root.refresh()

            BoxLayout:
                size_hint_y: None
                height: dp(36)
                spacing: dp(8)

                Button:
                    text: 'Copy Report'
                    font_size: font_size_sm
                    background_color: secondary_color
                    color: foreground_color
                    on_release: root.copy_report()

                Button:
                    text: 'Save to File'
                    font_size: font_size_sm
                    background_color: secondary_color
                    color: foreground_color
                    on_release: root.save_report()

            Label:
                text: root.report_status
                font_size: font_size_xs
                color: success_color if root.report_status else transparent
                size_hint_y: None
                height: dp(20) if root.report_status else 0
                halign: 'left'
                text_size: self.width, self.height

            BoxLayout:
                id: row_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(2)
