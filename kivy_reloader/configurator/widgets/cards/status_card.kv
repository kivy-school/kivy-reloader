<StatusRow>:
    size_hint_y: None
    height: dp(48)
    spacing: dp(12)
    padding: [dp(4), dp(4)]

    Label:
        text: unicode['check-circle'] if root.row_status == 'ok' else unicode['alert'] if root.row_status == 'warn' else unicode['close'] if root.row_status == 'fail' else unicode['minus']
        font_name: icon_font
        size_hint: None, None
        size: dp(28), dp(28)
        font_size: font_size_base
        bold: True
        color: (0.3, 0.85, 0.4, 1) if root.row_status == 'ok' else (1, 0.75, 0.2, 1) if root.row_status == 'warn' else (0.9, 0.3, 0.3, 1) if root.row_status == 'fail' else muted_foreground_color
        halign: 'center'
        valign: 'middle'
        text_size: self.size

    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)

        Label:
            text: root.label
            font_size: font_size_sm
            bold: True
            color: foreground_color
            halign: 'left'
            valign: 'middle'
            text_size: self.width, self.height

        Label:
            text: root.detail
            font_size: font_size_xs
            color: muted_foreground_color
            halign: 'left'
            valign: 'middle'
            text_size: self.width, self.height
            shorten: True
            shorten_from: 'right'


<DeviceRow>:
    orientation: 'horizontal'

    size_hint_y: None
    height: dp(56)
    spacing: dp(10)
    padding: [dp(4), dp(6)]

    # Status dot
    Widget:
        size_hint: None, None
        size: dp(10), dp(10)
        pos_hint: {'center_y': 0.5}
        canvas:
            Color:
                rgba: (0.3, 0.85, 0.4, 1) if root.device_status == 'ok' else (1, 0.75, 0.2, 1) if root.device_status == 'warn' else (0.9, 0.3, 0.3, 1)
            Ellipse:
                pos: self.pos
                size: self.size

    # USB / WIFI chip
    Label:
        text: root.connection
        size_hint: None, None
        size: dp(44), dp(22)
        pos_hint: {'center_y': 0.5}
        font_size: font_size_xs
        bold: True
        color: primary_foreground_color
        halign: 'center'
        valign: 'middle'
        text_size: self.size
        canvas.before:
            Color:
                rgba: primary_color if root.connection == 'WIFI' else secondary_color
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(4)]

    # Name + serial / detail
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)

        Label:
            text: root.name
            font_size: font_size_sm
            bold: True
            color: foreground_color
            halign: 'left'
            valign: 'middle'
            text_size: self.size

        Label:
            text: root.serial + '  —  ' + root.status_detail
            font_size: font_size_xs
            color: muted_foreground_color
            halign: 'left'
            valign: 'middle'
            text_size: self.size
            shorten: True
            shorten_from: 'right'

    # Recheck button
    Button:
        text: 'Recheck'
        size_hint: None, None
        size: dp(64), dp(28)
        pos_hint: {'center_y': 0.5}
        font_size: font_size_xs
        background_color: secondary_color
        color: foreground_color
        on_release: root.recheck()


<StatusCard>:
    orientation: 'vertical'
    size_hint_y: None
    height: self.minimum_height

    Card:
        title: f'[size=16][font={emoji_font}]📡[/font][/size] Status — {root.os_label}'
        description: 'Environment checks for your current OS and device setup.'

        BoxLayout:
            orientation: 'vertical'
            spacing: dp(8)
            size_hint_y: None
            height: self.minimum_height

            Separator:

            Button:
                text: 'Refresh'
                size_hint_y: None
                height: dp(36)
                font_size: font_size_sm
                background_color: primary_color
                color: primary_foreground_color
                on_release: root.refresh()

            BoxLayout:
                size_hint_y: None
                height: dp(36)
                spacing: dp(8)

                Button:
                    text: 'Copy Report'
                    font_size: font_size_sm
                    background_color: secondary_color
                    color: foreground_color
                    on_release: root.copy_report()

                Button:
                    text: 'Save to File'
                    font_size: font_size_sm
                    background_color: secondary_color
                    color: foreground_color
                    on_release: root.save_report()

                Button:
                    text: 'Reset Reloader State'
                    size_hint_y: None
                    height: dp(36)
                    font_size: font_size_sm
                    background_color: destructive_color
                    color: destructive_foreground_color
                    on_release: root.reset_reloader_state()


            BoxLayout:
                size_hint_y: None
                height: dp(24) if root.report_status else 0
                opacity: 1 if root.report_status else 0
                spacing: dp(6)

                Label:
                    text: unicode['check-circle']
                    font_name: icon_font
                    font_size: font_size_sm
                    color: success_color
                    size_hint: None, None
                    size: dp(20), dp(24)
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size

                Label:
                    text: root.report_status
                    font_size: font_size_xs
                    color: success_color
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width, self.height


            # Connected Devices
            Label:
                text: 'Connected Devices'
                font_size: font_size_xs
                bold: True
                color: muted_foreground_color
                size_hint_y: None
                height: dp(20)
                halign: 'left'
                text_size: self.width, self.height

            Label:
                text: 'No devices connected'
                font_size: font_size_sm
                color: muted_foreground_color
                size_hint_y: None
                height: dp(36) if not root.devices else 0
                opacity: 1 if not root.devices else 0
                halign: 'left'
                valign: 'middle'
                text_size: self.size

            BoxLayout:
                id: device_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(2)

            Separator:

            # Environment checklist
            BoxLayout:
                id: row_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(2)
