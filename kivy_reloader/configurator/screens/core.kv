#:import cards kivy_reloader.configurator.widgets.cards
#:import command_panel_mod kivy_reloader.configurator.widgets.command_panel 

<SectionBox@BoxLayout>:
    orientation: 'vertical'
    padding: [dp(32), dp(24), dp(32), dp(24)]
    spacing: dp(16)
    size_hint_y: None
    height: self.minimum_height

    canvas.before:
        Color:
            rgba: background_color
        Rectangle:
            pos: self.pos
            size: self.size


<SectionScrollView@ScrollView>:
    do_scroll_x: False
    do_scroll_y: True
    bar_width: dp(8)
    bar_color: muted_color
    bar_inactive_color: muted_color
    scroll_type: ['bars', 'content']


<SectionScreen>:
    section_box: section_box.__self__

    SectionScrollView:
        SectionBox:
            id: section_box


<CoreScreen>:
    toolbar: toolbar.__self__
    sidebar: sidebar.__self__
    section_manager: section_manager.__self__
    command_panel: command_panel.__self__

    canvas.before:
        Color:
            rgba: background_color
        Rectangle:
            pos: self.pos
            size: self.size
    
    BoxLayout:
        orientation: 'vertical'
        # Sidebar + main content (horizontal)
    
        BoxLayout:
            SideBar:
                id: sidebar
            BoxLayout:
                orientation: 'vertical'
                Toolbar:
                    id: toolbar
                ScreenManager:
                    id: section_manager
                    SectionScreen:
                        card_cls: cards.CoreCard
                        name: 'Core'
                    SectionScreen:
                        card_cls: cards.ServicesCard
                        name: 'Services'
                    SectionScreen:
                        card_cls: cards.DeviceCard
                        name: 'Device'
                    SectionScreen:
                        card_cls: cards.WindowCard
                        name: 'Window'
                    SectionScreen:
                        card_cls: cards.DisplayCard
                        name: 'Display'
                    SectionScreen:
                        card_cls: cards.AudioCard
                        name: 'Audio'
                    SectionScreen:
                        card_cls: cards.PerformanceCard
                        name: 'Performance'
                    SectionScreen:
                        card_cls: cards.AdvancedCard
                        name: 'Advanced'
                    SectionScreen:
                        card_cls: cards.DeploymentCard
                        name: 'Deployment'
                    SectionScreen:
                        card_cls: cards.NotificationsCard
                        name: 'Notifications'
        # Command panel pinned to bottom
        CommandPanel:
            id: command_panel
